# Backend API base URL (no trailing slash).
#
# Local dev: leave empty — Vite proxies /api to http://localhost:4000
# Vercel:    set VITE_API_URL in Project Settings → Environment Variables
#            (Production, Preview, Development as needed)
#            Example: https://po-tracker-api-v7iy.onrender.com
#
# Do not commit .env.production — configure on Vercel instead.
VITE_API_URL=
